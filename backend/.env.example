# ── VulnGuard Environment Configuration ─────────────────
# Copy this file to .env and update values for your environment.
# This file is loaded by python-dotenv in config.py

# ── Security ────────────────────────────────────────────
# Secret key used for JWT signing (HS256). Change in production!
SECRET_KEY=your-secret-key-change-in-production

# ── Database (MongoDB) ──────────────────────────────────
# Connection URI for the main MongoDB database
MONGO_URI=mongodb://localhost:27017/vulnguard

# Connection URI for the test database (used by TestingConfig)
TEST_MONGO_URI=mongodb://localhost:27017/vulnguard_test

# ── JWT Settings ────────────────────────────────────────
# Token expiry time in hours (default: 1)
JWT_EXPIRY_HOURS=1

# ── Pagination ──────────────────────────────────────────
# Default number of items per page (max: 100, set in config.py)
ITEMS_PER_PAGE=10

# ── Flask Settings ──────────────────────────────────────
# Environment mode: development | testing | production
FLASK_ENV=development

# Enable debug mode (hot-reload, detailed errors). Set to 0 in production.
FLASK_DEBUG=1
